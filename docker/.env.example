# RembugBot Environment Variables
# Copy to docker/.env and fill in real values.

# === WhatsApp Gateway ===
WA_AUTH_DIR=/data/auth
WA_GROUP_ALLOWLIST=group-jid-1@g.us
WA_BOT_NUMBER=628xxxxxxxxxx

# === Database ===
DB_PATH=/data/rembugbot.db

# === Temp / media storage (PDF downloads) ===
TEMP_DIR=/data/temp

# === AI Worker (HTTP) ===
WORKER_URL=http://worker:8000
# Min 16 characters
WORKER_AUTH_TOKEN=change-me-to-random-secret-min-16

# === Security ===
# Min 32 characters — used for participant JID HMAC (non-reversible)
HMAC_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
HMAC_KEY_VERSION=1

# === GitHub Models (worker) ===
GH_MODELS_TOKEN_A=ghp_xxxxxxxxxxxx
GH_MODELS_TOKEN_B=ghp_xxxxxxxxxxxx

# === Backup ===
BACKUP_S3_BUCKET=rembugbot-backups
BACKUP_S3_PREFIX=database/
AWS_REGION=ap-southeast-1

# === Alerts ===
ALERT_WEBHOOK_URL=
ALERT_ADMIN_JIDS=628xxxxxxxxxx@s.whatsapp.net

# === Retention ===
RETENTION_MESSAGES_DAYS=14
RETENTION_PDF_RAW_HOURS=24
RETENTION_SUMMARIES_DAYS=90
RETENTION_AUDIT_DAYS=90
RETENTION_LOGS_DAYS=30

# === Scheduler ===
SUMMARY_CRON_MORNING=0 8 * * *
SUMMARY_CRON_EVENING=0 20 * * *
SUMMARY_TIMEZONE=Asia/Jakarta
